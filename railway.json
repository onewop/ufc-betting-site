{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "./backend/Dockerfile"
  },
  "deploy": {
    "startCommand": "cd /app/backend && uvicorn main:app --host 0.0.0.0 --port ${PORT:-8000}",
    "restartPolicy": {
      "maxRetries": 10
    }
  }
}
